let editStockId = null;
function openEditStock(id) {
  const s = state.stocks.find(x=>x.id===id);
  if(!s) return;
  editStockId = id;

  // 填入現有資料
  document.getElementById('add-code').value = s.code;
  document.getElementById('add-name').value = s.name;
  document.getElementById('add-price').value = s.initPrice;
  document.getElementById('add-shares').value = s.initShares;
  document.getElementById('add-date').value = s.initDate;
  document.getElementById('add-note').value = s.note || '';
  document.getElementById('add-sell1').value = s.triggers?.sell1 || '';
  document.getElementById('add-buy2').value = s.triggers?.buy2 || '';
  document.getElementById('add-take').value = s.triggers?.take || '';

  // 顯示已選股票 badge，隱藏搜尋框
  document.getElementById('stock-search').value = '';
  document.getElementById('stock-search').style.display = 'none';
  document.getElementById('search-dropdown').style.display = 'none';
  const b = document.getElementById('selected-badge');
  b.style.display = 'flex';
  document.getElementById('badge-code').textContent = s.code;
  document.getElementById('badge-name').textContent = s.name;

  // 重置 ATR 區
  document.getElementById('atr-section').style.display = 'none';
  document.getElementById('suggestions').innerHTML = '';
  document.getElementById('atr-days').value = 14;
  document.getElementById('atr-sell-mult').value = 3;
  document.getElementById('atr-buy-mult').value = 5;
  document.getElementById('atr-take-mult').value = 2;
  atrRawData = [];

  // 改 modal 標題和按鈕文字
  document.querySelector('#modal-add .modal-title').textContent = '編輯股票設定';
  document.querySelector('#modal-add .modal-footer .btn-primary').textContent = '儲存變更';

  openModal('modal-add');
}

