let hlIdx=-1;
function onStockSearch(val){
  hlIdx=-1;
  const dd=document.getElementById('search-dropdown');
  if(!val||val.length<1){dd.style.display='none';return;}
  const kw=val.toLowerCase();
  const res=TW_STOCKS.filter(([c,n])=>c.toLowerCase().startsWith(kw)||n.includes(val)).slice(0,12);
  dd.style.display='block';
  const manualRow=`<div class="search-item" style="border-top:1px solid var(--border2)"
    onmousedown="selectItem('${val.toUpperCase()}','${val.toUpperCase()}',true)">
    <span class="si-code" style="color:var(--text3)">${val.toUpperCase()}</span>
    <span class="si-name" style="color:var(--text3);font-size:12px">直接使用此代號，自行輸入名稱</span>
  </div>`;
  if(!res.length){
    dd.innerHTML=`<div class="search-item" onmousedown="selectItem('${val.toUpperCase()}','${val.toUpperCase()}',true)">
      <span class="si-code">${val.toUpperCase()}</span>
      <span class="si-name" style="color:var(--text2)">找不到，點此使用並自行輸入名稱</span>
    </div>`;
    return;
  }
  dd.innerHTML=res.map(([c,n],i)=>
    `<div class="search-item" data-c="${c}" data-n="${n}" data-i="${i}"
      onmousedown="selectItem('${c}','${n}',false)" onmouseover="hlItem(${i})">
      <span class="si-code">${c}</span><span class="si-name">${n}</span>
    </div>`
  ).join('')+manualRow;
}
function hlItem(i){
  hlIdx=i;
  document.querySelectorAll('#search-dropdown .search-item').forEach((el,j)=>el.classList.toggle('hl',j===i));
}
function onSearchKey(e){
  const items=document.querySelectorAll('#search-dropdown .search-item');
  if(!items.length) return;
  if(e.key==='ArrowDown'){e.preventDefault();hlItem(Math.min(hlIdx+1,items.length-1));}
  if(e.key==='ArrowUp'){e.preventDefault();hlItem(Math.max(hlIdx-1,0));}
  if(e.key==='Enter'&&hlIdx>=0){
    const el=items[hlIdx];
    const isCustom=!el.dataset.n||el.dataset.c===el.dataset.n;
    selectItem(el.dataset.c||document.getElementById('stock-search').value.toUpperCase(),
               el.dataset.n||'', isCustom);
  }
  if(e.key==='Escape') document.getElementById('search-dropdown').style.display='none';
}
function selectItem(code, name, isCustom=false){
  document.getElementById('add-code').value = code;
  document.getElementById('add-name').value = isCustom ? code : name; // 自訂時先用代號，等用戶填名稱
  document.getElementById('stock-search').value = '';
  document.getElementById('stock-search').style.display = 'none';
  document.getElementById('search-dropdown').style.display = 'none';
  const b = document.getElementById('selected-badge');
  b.style.display = 'flex';
  document.getElementById('badge-code').textContent = code;

  if(isCustom){
    // 非內建：顯示名稱輸入框
    document.getElementById('badge-name-display').style.display = 'none';
    const nameInput = document.getElementById('badge-name-input');
    nameInput.style.display = 'block';
    nameInput.value = '';
    nameInput.placeholder = `輸入「${code}」的股票名稱（選填）`;
    setTimeout(()=>nameInput.focus(), 100);
  } else {
    // 內建：直接顯示名稱
    document.getElementById('badge-name-display').textContent = name;
    document.getElementById('badge-name-display').style.display = 'inline';
    document.getElementById('badge-name-input').style.display = 'none';
  }
  fetchATR(code);
}
function clearSelection(){
  document.getElementById('add-code').value='';
  document.getElementById('add-name').value='';
  document.getElementById('stock-search').value='';
  document.getElementById('stock-search').style.display='block';
  document.getElementById('selected-badge').style.display='none';
  document.getElementById('badge-name-display').textContent='';
  document.getElementById('badge-name-input').value='';
  document.getElementById('badge-name-input').style.display='none';
  document.getElementById('atr-section').style.display='none';
  document.getElementById('add-price').value='';
  atrRawData=[];
  setTimeout(()=>document.getElementById('stock-search').focus(),50);
}
document.addEventListener('click',e=>{
  if(!e.target.closest('#stock-search')&&!e.target.closest('#search-dropdown'))
    document.getElementById('search-dropdown').style.display='none';
});

// ══ ATR / FINMIND ══
async function fetchATR(code){
  if(!code) return;
  document.getElementById('atr-section').style.display='block';
  document.getElementById('atr-info').innerHTML=
    '<div class="atr-row"><span class="atr-label">狀態</span><span class="atr-val"><span class="loading-spinner"></span> FinMind 資料抓取中…</span></div>';
  document.getElementById('suggestions').innerHTML='';
  atrRawData=[];

  const start=new Date(); start.setDate(start.getDate()-90);
  const startStr=start.toISOString().slice(0,10);

  try{
    const params=new URLSearchParams({dataset:'TaiwanStockPrice',data_id:code,start_date:startStr,token:FM_TOKEN});
    const res=await fetch(`${FM_URL}?${params}`,{signal:AbortSignal.timeout(12000)});
    const json=await res.json();
    if(json.status!==200||!json.data?.length) throw new Error(json.msg||'no data');
    atrRawData=json.data;
    const last=atrRawData[atrRawData.length-1];
    const lastClose=parseFloat(last.close);
    if(!document.getElementById('add-price').value&&lastClose)
      document.getElementById('add-price').value=lastClose.toFixed(2);
    renderATRBox(lastClose,last.date);
    computeSuggestions();
  }catch(e){
    document.getElementById('atr-info').innerHTML=
      `<div class="atr-row"><span class="atr-label">狀態</span><span class="atr-val" style="color:var(--text2)">資料抓取失敗，改用固定比例建議</span></div>`;
    computeSuggestions();
  }
}

function calcATR(days){
  if(atrRawData.length<2) return null;
  let sum=0,cnt=0;
  for(let i=1;i<atrRawData.length;i++){
    const h=parseFloat(atrRawData[i].max),l=parseFloat(atrRawData[i].min),pc=parseFloat(atrRawData[i-1].close);
    const tr=Math.max(h-l,Math.abs(h-pc),Math.abs(l-pc));
    if(!isNaN(tr)&&tr>0){sum+=tr;cnt++;}
    if(cnt>=days) break;
  }
  return cnt>0?sum/cnt:null;
}

function renderATRBox(lastClose,lastDate){
  const days=parseInt(document.getElementById('atr-days').value)||14;
  const atr=calcATR(days);
  const pct=atr&&lastClose?(atr/lastClose*100).toFixed(2):null;
  document.getElementById('atr-info').innerHTML=`
    <div class="atr-row"><span class="atr-label">資料來源</span><span class="atr-val" style="color:var(--text2);font-size:11px">FinMind &nbsp;·&nbsp; ${lastDate}</span></div>
    <div class="atr-row"><span class="atr-label">最新收盤</span><span class="atr-val">$${fmt(lastClose)}</span></div>
    <div class="atr-row"><span class="atr-label">${days} 日 ATR</span><span class="atr-val warn">$${atr?fmt(atr):'資料不足'}</span></div>
    <div class="atr-row"><span class="atr-label">ATR 佔股價</span><span class="atr-val">${pct?pct+'%':'—'}</span></div>`;
}

function computeSuggestions(){
  const price=parseFloat(document.getElementById('add-price').value);
  if(!price) return;
  const days=parseInt(document.getElementById('atr-days').value)||14;
  const sm=parseFloat(document.getElementById('atr-sell-mult').value)||3;
  const bm=parseFloat(document.getElementById('atr-buy-mult').value)||5;
  const tm=parseFloat(document.getElementById('atr-take-mult').value)||2;

  if(atrRawData.length){
    const last=atrRawData[atrRawData.length-1];
    renderATRBox(parseFloat(last.close),last.date);
  }

  const atr=calcATR(days);
  let sell1,buy2,take,method;
  if(atr){
    sell1=Math.max(0,price-sm*atr);
    buy2=Math.max(0,price-bm*atr);
    take=price+tm*atr;
    method=`ATR(${days}) × ${sm} / × ${bm} / × ${tm}`;
  } else {
    sell1=price*0.70; buy2=price*0.50; take=price*1.20;
    method='固定比例：-30% / -50% / +20%';
  }

  // 計算相對於買入價的百分比差距
  function pctFromBuy(val){
    const p=(val-price)/price*100;
    return `<span style="font-size:11px;color:var(--text3);font-family:var(--mono)">${p>=0?'+':''}${p.toFixed(1)}%<span style="color:var(--text3);font-weight:400;font-size:10px"> vs 買入價</span></span>`;
  }

  document.getElementById('suggestions').innerHTML=`
    <div style="font-size:11px;color:var(--text3);margin-bottom:7px;padding:0 2px">${method}</div>
    <div class="suggestion-item">
      <div style="display:flex;flex-direction:column;gap:2px">
        <span class="suggestion-label">建議減倉觸發</span>
        ${pctFromBuy(sell1)}
      </div>
      <div class="suggestion-right">
        <span class="suggestion-val neg">$${fmt(sell1)}</span>
        <button class="btn btn-ghost btn-sm" type="button" onclick="applySugg('add-sell1',${sell1.toFixed(2)})">套用</button>
      </div>
    </div>
    <div class="suggestion-item">
      <div style="display:flex;flex-direction:column;gap:2px">
        <span class="suggestion-label">建議補倉觸發</span>
        ${pctFromBuy(buy2)}
      </div>
      <div class="suggestion-right">
        <span class="suggestion-val pos">$${fmt(buy2)}</span>
        <button class="btn btn-ghost btn-sm" type="button" onclick="applySugg('add-buy2',${buy2.toFixed(2)})">套用</button>
      </div>
    </div>
    <div class="suggestion-item">
      <div style="display:flex;flex-direction:column;gap:2px">
        <span class="suggestion-label">建議高拋觸發</span>
        ${pctFromBuy(take)}
      </div>
      <div class="suggestion-right">
        <span class="suggestion-val warn">$${fmt(take)}</span>
        <button class="btn btn-ghost btn-sm" type="button" onclick="applySugg('add-take',${take.toFixed(2)})">套用</button>
      </div>
    </div>`;
}

function applySugg(id,val){
  const el=document.getElementById(id);
  if(el){ el.value=Number(val).toFixed(2); }
}

// ══ 手續費試算 ══
function calcFee(){
  const price=parseFloat(document.getElementById('add-price').value);
  const shares=parseInt(document.getElementById('add-shares').value);
  const feeBox=document.getElementById('fee-box');

  if(isNaN(price)||isNaN(shares)||price<=0||shares<=0){
    feeBox.style.display='none'; return;
  }
  feeBox.style.display='block';

  const discount=(parseFloat(document.getElementById('fee-discount').value)||28)/100;
  const isETF=document.getElementById('fee-is-etf').checked;
  const total=price*shares;

  // 買進手續費：成交金額 × 0.1425% × 折扣，最低20元，無條件捨去
  const buyFee=Math.max(Math.floor(total*0.001425*discount), 20);
  // 賣出手續費：同上
  const sellFee=Math.max(Math.floor(total*0.001425*discount), 20);
  // 證交稅：ETF 0.1%，股票 0.3%，無條件捨去
  const taxRate=isETF?0.001:0.003;
  const tax=Math.floor(total*taxRate);
  const roundtrip=buyFee+sellFee+tax;

  document.getElementById('fee-total').textContent='$'+total.toLocaleString('zh-TW');
  document.getElementById('fee-buy').textContent='$'+buyFee.toLocaleString('zh-TW');
  document.getElementById('fee-sell').textContent='$'+sellFee.toLocaleString('zh-TW');
  document.getElementById('fee-tax').textContent='$'+tax.toLocaleString('zh-TW');
  document.getElementById('fee-roundtrip').textContent='$'+roundtrip.toLocaleString('zh-TW');
}

