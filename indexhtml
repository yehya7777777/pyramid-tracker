<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pyramid Tracker｜金字塔解套追蹤器</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Noto+Sans+TC:wght@300;400;500;700&display=swap" rel="stylesheet">
<script type="module">
// ══ FIREBASE INIT ══
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getAuth, GoogleAuthProvider, signInWithPopup, signOut, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";
import { getFirestore, doc, setDoc, onSnapshot } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";
const firebaseConfig={apiKey:"AIzaSyB9bc1ngTUIK5Yn-IUMqMBlwwz7enuxaac",authDomain:"pyramid-tracker-1210c.firebaseapp.com",projectId:"pyramid-tracker-1210c",storageBucket:"pyramid-tracker-1210c.firebasestorage.app",messagingSenderId:"49532699634",appId:"1:49532699634:web:edbe5465e90c4c5969a16b"};
const fbApp=initializeApp(firebaseConfig);
const auth=getAuth(fbApp);
const db=getFirestore(fbApp);
const provider=new GoogleAuthProvider();
let currentUser=null,unsubSnap=null;
window._fbSignIn=async()=>{try{await signInWithPopup(auth,provider);}catch(e){alert("登入失敗："+e.message);}};
window._fbSignOut=async()=>{if(unsubSnap){unsubSnap();unsubSnap=null;}await signOut(auth);};
window._fbSave=async(data)=>{if(!currentUser)return;try{await setDoc(doc(db,"users",currentUser.uid,"data","stocks"),{payload:JSON.stringify(data),ts:Date.now()});}catch(e){console.error(e);}};
onAuthStateChanged(auth,user=>{currentUser=user;if(window._onAuthChange)window._onAuthChange(user);if(user){if(unsubSnap)unsubSnap();unsubSnap=onSnapshot(doc(db,"users",user.uid,"data","stocks"),snap=>{if(snap.exists()&&window._onRemoteData)window._onRemoteData(snap.data());});}});
</script>
<style>
:root{
  --bg:#080b12;--bg2:#0d1220;--bg3:#111828;--card:#141d2e;
  --border:#1e2a40;--border2:#253448;--text:#e2e8f8;--text2:#7888aa;--text3:#3d4f6e;
  --accent:#4f8ef7;--accent2:#2563eb;--green:#10c97a;--green2:#052e1a;
  --red:#f06060;--red2:#3d1010;--yellow:#f0b840;--yellow2:#3d2800;--purple:#a78bfa;
  --mono:'DM Mono',monospace;--sans:'Noto Sans TC',sans-serif;
  /* 字體大小體系 */
  --fs-xs:12px;   /* 輔助標籤、說明文字 */
  --fs-sm:14px;   /* 次要資訊、badge */
  --fs-base:16px; /* 全站基準 */
  --fs-md:17px;   /* 一般內文 */
  --fs-lg:20px;   /* 數值、重要資料 */
  --fs-xl:24px;   /* 卡片主數字 */
  --fs-2xl:28px;  /* 標題 */
}
html{font-size:var(--fs-base);}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:var(--sans);min-height:100vh;font-size:var(--fs-base);line-height:1.6;}
.app{display:grid;grid-template-rows:auto 1fr;min-height:100vh;}
header{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 16px;
  min-height:54px;display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:100;flex-wrap:wrap;gap:6px;}
.logo{font-family:var(--mono);font-size:var(--fs-base);color:var(--accent);letter-spacing:.08em;}
.logo span{color:var(--text2);}
.main{display:grid;grid-template-columns:300px 1fr;min-height:calc(100vh - 54px);}
.sidebar{background:var(--bg2);border-right:1px solid var(--border);overflow-y:auto;display:flex;flex-direction:column;}
.sidebar-header{padding:14px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.sidebar-title{font-size:var(--fs-xs);font-weight:600;color:var(--text2);letter-spacing:.1em;text-transform:uppercase;}
.stock-list{padding:6px;flex:1;overflow-y:auto;}
.stock-item{padding:13px;border-radius:8px;cursor:pointer;margin-bottom:4px;border:1px solid transparent;transition:all .15s;}
.stock-item:hover{background:var(--bg3);border-color:var(--border);}
.stock-item.active{background:var(--card);border-color:var(--accent);}
.stock-item-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;}
.stock-code{font-family:var(--mono);font-size:var(--fs-base);font-weight:600;}
.stock-pnl{font-family:var(--mono);font-size:var(--fs-sm);}
.stock-name{font-size:var(--fs-sm);color:var(--text2);margin-bottom:6px;}
.stock-mini{display:flex;gap:6px;flex-wrap:wrap;}
.mini-chip{font-size:var(--fs-xs);font-family:var(--mono);padding:3px 8px;border-radius:4px;background:var(--bg3);color:var(--text2);}
.alert-dot{width:7px;height:7px;border-radius:50%;background:var(--yellow);animation:pulse 2s infinite;flex-shrink:0;}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.content{overflow-y:auto;padding:24px;}
.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:16px;color:var(--text3);}
.empty-icon{font-size:52px;opacity:.3;}
/* STATS */
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:22px;}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:16px 18px;}
.stat-label{font-size:var(--fs-sm);color:var(--text2);letter-spacing:.04em;text-transform:uppercase;margin-bottom:7px;font-weight:500;}
.stat-value{font-family:var(--mono);font-size:var(--fs-xl);font-weight:600;}
.stat-sub{font-size:var(--fs-sm);color:var(--text2);margin-top:5px;font-family:var(--mono);}
.pos{color:#e84040;}.neg{color:#10c97a;}.neu{color:var(--text);}.warn{color:var(--yellow);}
/* PANELS */
.panel{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:20px;margin-bottom:20px;}
.panel-title{font-size:var(--fs-sm);font-weight:700;color:var(--text2);letter-spacing:.06em;text-transform:uppercase;margin-bottom:16px;display:flex;align-items:center;gap:8px;}
.triggers{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:12px;}
.trigger-item{background:var(--bg3);border-radius:8px;padding:16px;border-left:4px solid var(--border2);}
.trigger-item.sell{border-left-color:var(--yellow);}
.trigger-item.buy{border-left-color:var(--green);}
.trigger-item.take{border-left-color:var(--red);}
.trigger-type{font-size:var(--fs-sm);color:var(--text2);text-transform:uppercase;letter-spacing:.04em;margin-bottom:7px;font-weight:500;}
.trigger-price{font-family:var(--mono);font-size:var(--fs-xl);font-weight:600;}
.trigger-dist{font-size:var(--fs-sm);color:var(--text2);margin-top:6px;font-family:var(--mono);}
.trigger-edit{margin-top:8px;}
.trigger-edit input{width:100%;background:var(--bg2);border:1px solid var(--border2);border-radius:4px;
  color:var(--text);font-family:var(--mono);font-size:var(--fs-base);padding:6px 10px;}
.trigger-edit input:focus{outline:none;border-color:var(--accent);}
/* TX TABLE */
.tx-table{width:100%;border-collapse:collapse;}
.tx-table th{font-size:var(--fs-xs);color:var(--text2);text-transform:uppercase;letter-spacing:.06em;
  padding:10px 12px;text-align:left;border-bottom:1px solid var(--border);font-weight:600;}
.tx-table td{padding:12px 12px;font-size:var(--fs-base);border-bottom:1px solid var(--border);vertical-align:middle;}
.tx-table tr:last-child td{border-bottom:none;}
.tx-type{font-size:var(--fs-xs);font-weight:600;padding:4px 9px;border-radius:4px;font-family:var(--mono);white-space:nowrap;}
.tx-type.buy{background:var(--green2);color:var(--green);}
.tx-type.sell{background:var(--red2);color:var(--red);}
.tx-type.dca{background:#1e3a5f;color:#60a5fa;}
.tx-mono{font-family:var(--mono);}
.tx-note{font-size:var(--fs-sm);color:var(--text2);}
.delete-btn{opacity:0;transition:opacity .15s;}
tr:hover .delete-btn{opacity:1;}
/* BUTTONS */
.btn{padding:9px 17px;border-radius:6px;font-size:var(--fs-base);font-family:var(--sans);cursor:pointer;
  border:none;font-weight:500;transition:all .15s;display:inline-flex;align-items:center;gap:6px;}
.btn-primary{background:var(--accent);color:#fff;}.btn-primary:hover{background:var(--accent2);}
.btn-ghost{background:transparent;color:var(--text2);border:1px solid var(--border2);}
.btn-ghost:hover{background:var(--bg3);color:var(--text);}
.btn-danger{background:transparent;color:var(--red);border:1px solid var(--red2);}
.btn-danger:hover{background:var(--red2);}
.btn-green{background:var(--green);color:#fff;}.btn-green:hover{opacity:.85;}
.btn-red{background:var(--red);color:#fff;}.btn-red:hover{opacity:.85;}
.btn-blue{background:#1d4ed8;color:#fff;}.btn-blue:hover{opacity:.85;}
.btn-sm{padding:7px 13px;font-size:var(--fs-sm);}
.btn-icon{padding:6px;width:32px;height:32px;justify-content:center;}
/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:1000;
  display:flex;align-items:center;justify-content:center;padding:16px;
  opacity:0;pointer-events:none;transition:opacity .2s;}
.modal-overlay.open{opacity:1;pointer-events:all;}
.modal{background:var(--bg2);border:1px solid var(--border2);border-radius:12px;
  width:100%;max-width:540px;max-height:92vh;overflow-y:auto;
  transform:translateY(8px);transition:transform .2s;}
.modal-overlay.open .modal{transform:translateY(0);}
.modal-header{padding:22px 26px 18px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;}
.modal-title{font-size:var(--fs-lg);font-weight:700;}
.modal-body{padding:22px 26px;display:flex;flex-direction:column;gap:16px;}
.modal-footer{padding:18px 26px;border-top:1px solid var(--border);display:flex;gap:10px;justify-content:flex-end;}
.form-group{display:flex;flex-direction:column;gap:7px;}
.form-label{font-size:var(--fs-sm);color:var(--text2);font-weight:600;}
.form-input{background:var(--bg3);border:1px solid var(--border2);border-radius:6px;
  color:var(--text);font-family:var(--sans);font-size:var(--fs-base);padding:10px 13px;width:100%;}
.form-input:focus{outline:none;border-color:var(--accent);}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.form-hint{font-size:var(--fs-xs);color:var(--text3);margin-top:2px;}
select.form-input{appearance:none;cursor:pointer;}
.close-btn{background:none;border:none;color:var(--text2);cursor:pointer;font-size:24px;line-height:1;padding:2px;}
.close-btn:hover{color:var(--text);}
.loading-spinner{display:inline-block;width:14px;height:14px;border:2px solid var(--border);
  border-top-color:var(--accent);border-radius:50%;animation:spin .6s linear infinite;}
@keyframes spin{to{transform:rotate(360deg)}}
.section-divider{display:flex;align-items:center;gap:8px;margin:4px 0 2px;}
.section-divider span{font-size:var(--fs-xs);color:var(--text2);text-transform:uppercase;letter-spacing:.1em;white-space:nowrap;}
.section-divider::before,.section-divider::after{content:'';flex:1;height:1px;background:var(--border);}
.badge{font-size:var(--fs-xs);padding:3px 8px;border-radius:10px;font-family:var(--mono);}
.badge-yellow{background:var(--yellow2);color:var(--yellow);}
/* SEARCH */
.search-wrap{position:relative;}
#search-dropdown{display:none;position:absolute;top:calc(100% + 4px);left:0;right:0;z-index:9999;
  background:var(--bg2);border:1px solid var(--border2);border-radius:8px;
  max-height:260px;overflow-y:auto;box-shadow:0 8px 24px rgba(0,0,0,.5);}
.search-item{padding:11px 15px;cursor:pointer;display:flex;justify-content:space-between;
  align-items:center;font-size:var(--fs-base);border-bottom:1px solid var(--border);}
.search-item:last-child{border-bottom:none;}
.search-item:hover,.search-item.hl{background:var(--bg3);}
.si-code{font-family:var(--mono);color:var(--accent);min-width:80px;flex-shrink:0;}
.si-name{color:var(--text);}
/* ATR BOX */
.atr-box{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:13px 16px;}
.atr-row{display:flex;justify-content:space-between;align-items:center;padding:4px 0;font-size:var(--fs-sm);}
.atr-label{color:var(--text2);}
.atr-val{font-family:var(--mono);font-weight:500;}
/* ATR CONTROLS */
.atr-controls{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:12px 0 10px;}
.atr-ctrl{display:flex;flex-direction:column;gap:5px;}
.atr-ctrl label{font-size:var(--fs-sm);color:var(--text2);}
.atr-ctrl input{background:var(--bg2);border:1px solid var(--border2);border-radius:5px;
  color:var(--text);font-family:var(--mono);font-size:var(--fs-base);padding:7px 9px;width:100%;}
.atr-ctrl input:focus{outline:none;border-color:var(--accent);}
/* SUGGESTION */
.suggestion-item{display:flex;justify-content:space-between;align-items:center;
  background:var(--bg3);border-radius:6px;padding:10px 14px;margin-bottom:8px;}
.suggestion-label{color:var(--text2);font-size:var(--fs-sm);}
.suggestion-right{display:flex;gap:10px;align-items:center;}
.suggestion-val{font-family:var(--mono);font-weight:500;font-size:var(--fs-base);}
/* NOTE */
.note-item{display:flex;gap:12px;align-items:flex-start;padding:12px;
  background:var(--bg3);border-radius:6px;margin-bottom:8px;border-left:3px solid var(--border2);}
.note-item.warn{border-left-color:var(--yellow);}
.note-item.info{border-left-color:var(--accent);}
.note-text{font-size:var(--fs-base);margin-bottom:3px;}
.note-date{font-size:var(--fs-sm);color:var(--text2);font-family:var(--mono);}
/* MOBILE */
@media(max-width:768px){
  .main{grid-template-columns:1fr;}
  .sidebar{display:none;}
  .sidebar.mobile-open{display:flex;position:fixed;top:0;left:0;right:0;bottom:0;margin-top:54px;z-index:90;}
  .content{padding:16px;}
  .stats-grid{grid-template-columns:repeat(2,1fr);}
  .triggers{grid-template-columns:1fr;}
  .form-row{grid-template-columns:1fr;}
  .atr-controls{grid-template-columns:1fr 1fr;}
  .mobile-btn{display:flex!important;}
  .tx-table th:nth-child(4),.tx-table td:nth-child(4),
  .tx-table th:nth-child(5),.tx-table td:nth-child(5){display:none;}
  header{padding:8px 14px;}
  .header-right{flex-wrap:wrap;justify-content:flex-end;}
  .stat-value{font-size:var(--fs-lg);}
}
.mobile-btn{display:none;}
</style>
</head>
<body>
<div class="app">
<header>
  <div>
    <div class="logo">PYRAMID<span>.TRACKER</span></div>
    <div style="font-size:11px;color:var(--text3);letter-spacing:.06em;margin-top:1px">金字塔解套追蹤器</div>
  </div>
  <div class="header-right" style="display:flex;gap:7px;align-items:center">
    <button class="btn btn-ghost btn-sm mobile-btn" onclick="toggleSidebar()">☰</button>
    <div id="auth-area" style="display:flex;align-items:center;gap:7px">
      <button id="btn-signin" class="btn btn-ghost btn-sm" onclick="window._fbSignIn()" style="border-color:var(--accent);color:var(--accent)">
        <svg width="14" height="14" viewBox="0 0 24 24" style="flex-shrink:0"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        登入
      </button>
      <div id="user-info" style="display:none;align-items:center;gap:6px">
        <img id="user-avatar" width="22" height="22" style="border-radius:50%;flex-shrink:0" src="">
        <span id="user-name" style="font-size:12px;color:var(--text2);max-width:72px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"></span>
        <div id="sync-dot" style="width:6px;height:6px;border-radius:50%;background:var(--text3);flex-shrink:0" title="同步狀態"></div>
        <button class="btn btn-ghost btn-sm" onclick="window._fbSignOut()">登出</button>
      </div>
    </div>
    <button class="btn btn-ghost btn-sm" onclick="exportData()">⬇ 匯出</button>
    <label class="btn btn-ghost btn-sm" style="cursor:pointer">
      ⬆ 匯入<input type="file" accept=".json" style="display:none" onchange="importData(event)">
    </label>
    <button class="btn btn-ghost btn-sm" onclick="toggleGuide()" id="btn-guide">📖 使用說明</button>
    <button class="btn btn-primary btn-sm" onclick="openAddStock()">＋ 新增股票</button>
  </div>
</header>

<div class="main">
  <div class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <span class="sidebar-title">持倉股票</span>
      <span id="stock-count" style="font-family:var(--mono);font-size:12px;color:var(--text2)">0 檔</span>
    </div>
    <div style="padding:8px;border-bottom:1px solid var(--border);flex-shrink:0">
      <input class="form-input" id="sidebar-search" placeholder="搜尋股票代號或名稱…"
        style="padding:6px 10px;font-size:12px;background:var(--bg3)"
        oninput="renderSidebar()">
    </div>
    <div class="stock-list" id="stock-list"></div>
  </div>
  <div class="content" id="content">
    <div class="empty-state" id="empty-state">
      <div class="empty-icon">📊</div>
      <p style="font-size:16px;color:var(--text2)">尚無持倉股票</p>
      <p style="font-size:14px;color:var(--text3)">點擊右上角「新增股票」開始記錄</p>
      <button class="btn btn-primary" onclick="openAddStock()">＋ 新增第一檔股票</button>
    </div>
    <div id="stock-detail" style="display:none"></div>

    <!-- 說明頁（由 JS 動態填入） -->
    <div id="guide-page" style="display:none;max-width:720px;margin:0 auto;padding-bottom:40px"></div>
  </div>
</div>
</div>

<!-- ADD STOCK MODAL -->
<div class="modal-overlay" id="modal-add">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-title">新增股票</span>
      <button class="close-btn" onclick="closeModal('modal-add')">×</button>
    </div>
    <div class="modal-body">
      <div class="form-group search-wrap">
        <label class="form-label">搜尋股票（代號或名稱）</label>
        <input class="form-input" id="stock-search" placeholder="輸入代號或中文名稱，例：2330 或 台積電"
          autocomplete="off" oninput="onStockSearch(this.value)" onkeydown="onSearchKey(event)">
        <div id="search-dropdown"></div>
      </div>
      <div id="selected-badge" style="display:none;background:var(--bg3);border:1px solid var(--border2);
        border-radius:8px;padding:10px 14px;align-items:center;justify-content:space-between;gap:10px">
        <div style="display:flex;align-items:center;gap:10px;flex:1;min-width:0">
          <span style="font-family:var(--mono);font-weight:600;color:var(--accent);flex-shrink:0" id="badge-code"></span>
          <span id="badge-name-display" style="color:var(--text2);font-size:var(--fs-sm)"></span>
          <!-- 自訂名稱輸入（只在非內建股票時出現） -->
          <input type="text" id="badge-name-input" placeholder="輸入股票名稱（選填）"
            style="display:none;background:var(--bg2);border:1px solid var(--border2);border-radius:5px;
              color:var(--text);font-size:var(--fs-sm);padding:5px 9px;flex:1;min-width:0"
            oninput="document.getElementById('add-name').value=this.value||document.getElementById('add-code').value">
        </div>
        <button class="btn btn-ghost btn-sm" type="button" onclick="clearSelection()" style="flex-shrink:0">重新選擇</button>
      </div>
      <input type="hidden" id="add-code">
      <input type="hidden" id="add-name">

      <div class="section-divider"><span>建倉資訊</span></div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">買入價格（元）</label>
          <input class="form-input" id="add-price" type="number" step="0.01" placeholder="自動帶入收盤價" oninput="computeSuggestions();calcFee()">
        </div>
