document.getElementById('tx-type').addEventListener('change',updateTxHint);

function submitTx(){
  const price=parseFloat(document.getElementById('tx-price').value);
  const shares=parseInt(document.getElementById('tx-shares').value);
  if(isNaN(price)||isNaN(shares)||shares<=0){alert('請填寫價格和股數');return;}
  const s=state.stocks.find(x=>x.id===txStockId);
  if(!s.transactions) s.transactions=[];

  if(editTxId){
    const tx=s.transactions.find(t=>t.id===editTxId);
    if(tx){
      tx.type=document.getElementById('tx-type').value;
      tx.price=price; tx.shares=shares;
      tx.date=document.getElementById('tx-date').value;
      tx.note=document.getElementById('tx-note').value.trim();
      tx.flag=document.getElementById('tx-flag').checked;
    }
    editTxId=null;
    document.querySelector('#modal-tx .modal-title').textContent='記錄交易';
    document.querySelector('#modal-tx .modal-footer .btn-primary').textContent='記錄交易';
  } else {
    s.transactions.push({
      id:uid(), type:document.getElementById('tx-type').value,
      price, shares,
      date:document.getElementById('tx-date').value,
      note:document.getElementById('tx-note').value.trim(),
      flag:document.getElementById('tx-flag').checked
    });
    s.currentPrice=price;
  }
  saveState(); closeModal('modal-tx'); selectStock(txStockId);
}

