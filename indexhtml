let txStockId=null;
let editTxId=null;

function calcTxModalFee(){
  const price=parseFloat(document.getElementById('tx-price').value);
  const shares=parseInt(document.getElementById('tx-shares').value);
  const box=document.getElementById('tx-fee-box');
  if(isNaN(price)||isNaN(shares)||price<=0||shares<=0){box.style.display='none';return;}
  box.style.display='block';
  const discount=(parseFloat(document.getElementById('tx-fee-discount').value)||28)/100;
  const isETF=document.getElementById('tx-fee-is-etf').checked;
  const txType=document.getElementById('tx-type').value;
  const total=price*shares;
  const fee=Math.max(Math.floor(total*0.001425*discount),20);
  const tax=txType==='sell'?Math.floor(total*(isETF?0.001:0.003)):0;
  document.getElementById('tx-fee-total').textContent='$'+total.toLocaleString('zh-TW');
  document.getElementById('tx-fee-amt').textContent='$'+fee.toLocaleString('zh-TW');
  document.getElementById('tx-fee-tax').textContent=txType==='sell'?'$'+tax.toLocaleString('zh-TW'):'（買入免稅）';
  document.getElementById('tx-fee-tax').style.color=txType==='sell'?'var(--red)':'var(--text3)';
}

