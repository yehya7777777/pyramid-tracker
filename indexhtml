function buildViz(s,c,price){
  const t=s.triggers||{};
  const allTx=s.transactions||[];

  // ── 分離不同類型交易 ──
  const dcaTx  = allTx.filter(tx=>tx.type==='dca');
  const buyTx  = allTx.filter(tx=>tx.type==='buy');
  const sellTx = allTx.filter(tx=>tx.type==='sell');

  // ── DCA 均價線 ──
  let dcaAvg=null, dcaCount=0, dcaTotalShares=0;
  if(dcaTx.length>0){
    let costSum=0, shareSum=0;
    // 加入初始建倉
    costSum+=s.initPrice*s.initShares; shareSum+=s.initShares;
    dcaTx.forEach(tx=>{ costSum+=tx.price*tx.shares; shareSum+=tx.shares; });
    dcaAvg=costSum/shareSum;
    dcaCount=dcaTx.length;
    dcaTotalShares=shareSum;
  }

  // ── DCA 按價格區間分組 ──
  // 區間大小 = 整個價格範圍的 6%
  const pts=[s.initPrice, price, c.avgCost];
  if(t.sell1) pts.push(t.sell1);
  if(t.buy2)  pts.push(t.buy2);
  if(t.take)  pts.push(t.take);
  allTx.forEach(tx=>pts.push(tx.price));
  const minP=Math.min(...pts)*0.93, maxP=Math.max(...pts)*1.07;
  const priceRange=maxP-minP;
  const zoneSize=priceRange*0.06;

  // 把 DCA（含初始建倉）分組
  const dcaAll=[{price:s.initPrice, shares:s.initShares},...dcaTx.map(tx=>({price:tx.price,shares:tx.shares}))];
  const zones=[];
  dcaAll.forEach(item=>{
    const existing=zones.find(z=>Math.abs(z.centerPrice-item.price)<zoneSize);
    if(existing){
      existing.prices.push(item.price);
      existing.totalShares+=item.shares;
      existing.centerPrice=existing.prices.reduce((a,b)=>a+b,0)/existing.prices.length;
    } else {
      zones.push({centerPrice:item.price, prices:[item.price], totalShares:item.shares, count:1});
    }
  });
  zones.forEach(z=>z.count=z.prices.length);

  const W=560,H=140,PL=62,PR=22;
  const px=p=>PL+(p-minP)/(maxP-minP)*(W-PL-PR);

  // ── 收集所有標籤（碰撞偵測用）──
  function estW(txt){ return txt.length*5.6; }
  const labelItems=[];
  const addLabel=(val,color,txt,bold=false)=>{
    if(val===null||val===undefined||isNaN(val)) return;
    labelItems.push({x:px(val),color,txt,w:estW(txt),bold});
  };

  // 五條關鍵線的標籤
  addLabel(t.buy2,   '#10c97a',`補 $${fmt(t.buy2)}`);
  addLabel(t.sell1,  '#f0b840',`減 $${fmt(t.sell1)}`);
  addLabel(t.take,   '#e84040',`拋 $${fmt(t.take)}`);
  addLabel(c.avgCost,'#a78bfa',`均 $${fmt(c.avgCost)}`);
  addLabel(price,    '#ffffff',`現 $${fmt(price)}`,true);

  // DCA 均價線標籤已移除，只保留圓點群組

  // 非DCA買賣的標籤
  buyTx.forEach(tx=>addLabel(tx.price,'#10c97a',`補 $${fmt(tx.price)}`));
  sellTx.forEach(tx=>addLabel(tx.price,'#e84040',`賣 $${fmt(tx.price)}`));

  // 碰撞偵測
  labelItems.sort((a,b)=>a.x-b.x);
  const MIN_GAP=5, ROW_H=13, BASE_Y=H+15;
  const rows=[];
  labelItems.forEach(item=>{
    let assigned=-1;
    for(let r=0;r<8;r++){
      const edge=rows[r]??-Infinity;
      if(item.x-item.w/2>edge+MIN_GAP){assigned=r;break;}
    }
    if(assigned===-1) assigned=7;
    rows[assigned]=item.x+item.w/2;
    item.row=assigned;
  });
  const maxRow=labelItems.length?Math.max(...labelItems.map(l=>l.row)):0;
  const svgH=H+20+ROW_H*(maxRow+1);

  // ── 建構 SVG ──
  let svg=`<svg viewBox="0 0 ${W} ${svgH}" width="100%" style="overflow:visible">`;

  // 座標軸
  svg+=`<text x="${PL-5}" y="12" text-anchor="end" fill="var(--text3)" font-size="9" font-family="var(--mono)">$${fmt(maxP,0)}</text>`;
  svg+=`<text x="${PL-5}" y="${H+4}" text-anchor="end" fill="var(--text3)" font-size="9" font-family="var(--mono)">$${fmt(minP,0)}</text>`;
  svg+=`<line x1="${PL}" y1="6" x2="${W-PR}" y2="6" stroke="var(--border)" stroke-width="0.5"/>`;
  svg+=`<line x1="${PL}" y1="${H}" x2="${W-PR}" y2="${H}" stroke="var(--border)" stroke-width="0.5"/>`;

  // 關鍵虛線
  const dline=(val,color,sw=1.2,da='4 3',op=.85)=>{
    if(!val&&val!==0) return '';
    const x=px(val);
    return `<line x1="${x}" y1="5" x2="${x}" y2="${H+1}" stroke="${color}" stroke-width="${sw}" stroke-dasharray="${da}" opacity="${op}"/>`;
  };
  svg+=dline(t.buy2,'#10c97a');
  svg+=dline(t.sell1,'#f0b840');
  svg+=dline(t.take,'#e84040');
  svg+=dline(c.avgCost,'#a78bfa',1.5,'5 3',.7);

  // DCA 均價線已移除

  // DCA 區間群組點
  zones.forEach(z=>{
    const x=px(z.centerPrice);
    const r=Math.min(4+z.count*1.5, 12); // 筆數越多點越大，上限12
    const opacity=Math.min(0.5+z.count*0.08, 0.95);
    svg+=`<circle cx="${x}" cy="${H/2}" r="${r}" fill="#3b82f6" opacity="${opacity}"/>`;
    // 超過1筆才顯示數量
    if(z.count>1){
      svg+=`<text x="${x}" y="${H/2+4}" text-anchor="middle" fill="#fff" font-size="8" font-family="var(--mono)" font-weight="600">${z.count}</text>`;
    }
  });

  // 非DCA買賣點
  buyTx.forEach(tx=>{
    svg+=`<circle cx="${px(tx.price)}" cy="${H/2}" r="6" fill="#10c97a" opacity=".9"/>`;
  });
  sellTx.forEach(tx=>{
    svg+=`<circle cx="${px(tx.price)}" cy="${H/2}" r="6" fill="#e84040" opacity=".9"/>`;
  });

  // 現價箭頭
  const cp=px(price);
  svg+=`<line x1="${cp}" y1="4" x2="${cp}" y2="${H+1}" stroke="#ffffff" stroke-width="2"/>`;
  svg+=`<polygon points="${cp},2 ${cp-5},10 ${cp+5},10" fill="#ffffff"/>`;

  // 所有標籤（含引線）
  labelItems.forEach(item=>{
    const y=BASE_Y+item.row*ROW_H;
    if(item.row>0){
      svg+=`<line x1="${item.x}" y1="${H+2}" x2="${item.x}" y2="${y-4}" stroke="${item.color}" stroke-width="0.5" opacity=".35"/>`;
    }
    svg+=`<text x="${item.x}" y="${y}" text-anchor="middle" fill="${item.color}"
      font-size="9" font-family="var(--mono)" font-weight="${item.bold?'700':'400'}">${item.txt}</text>`;
  });

  svg+='</svg>';
  return svg;
}

// ══ ACTIONS ══
function updatePrice(id){
  const v=parseFloat(document.getElementById('price-input').value);
  if(isNaN(v)) return;
  const s=state.stocks.find(x=>x.id===id);
  s.currentPrice=v; saveState(); renderDetail(s); renderSidebar();
}
function updateTrigger(id,key,val){
  const s=state.stocks.find(x=>x.id===id);
  if(!s.triggers) s.triggers={};
  s.triggers[key]=parseFloat(val)||null;
  saveState(); renderSidebar();
}
function deleteTx(sid,tid){
  const s=state.stocks.find(x=>x.id===sid);
  s.transactions=(s.transactions||[]).filter(t=>t.id!==tid);
  saveState(); renderDetail(s); renderSidebar();
}
function deleteNote(sid,nid){
  const s=state.stocks.find(x=>x.id===sid);
  s.notes=(s.notes||[]).filter(n=>n.id!==nid);
  saveState(); renderDetail(s);
}
function deleteStock(id){
  if(!confirm('確定刪除此股票的所有記錄？')) return;
  state.stocks=state.stocks.filter(x=>x.id!==id);
  activeId=state.stocks[0]?.id||null;
  saveState(); render();
}

// ══ EXPORT / IMPORT ══
function exportData(){
  const blob=new Blob([JSON.stringify(state,null,2)],{type:'application/json'});
  const a=document.createElement('a');
  a.href=URL.createObjectURL(blob); a.download=`pyramid_${today()}.json`; a.click();
}
function importData(e){
  const file=e.target.files[0]; if(!file) return;
  const r=new FileReader();
  r.onload=ev=>{
    try{
      const d=JSON.parse(ev.target.result);
      if(!d.stocks) throw new Error('格式錯誤');
      state=d; saveState();
      activeId=state.stocks[0]?.id||null;
      render();
      alert(`✅ 匯入成功，共 ${state.stocks.length} 檔股票`);
    }catch(err){ alert('匯入失敗：'+err.message); }
  };
  r.readAsText(file); e.target.value='';
}

