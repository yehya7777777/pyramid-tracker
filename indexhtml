function openAddStock(){
  editStockId=null;
  document.querySelector('#modal-add .modal-title').textContent='新增股票';
  document.querySelector('#modal-add .modal-footer .btn-primary').textContent='建立股票';
  ['add-code','add-name','add-price','add-shares','add-sell1','add-buy2','add-take','add-note']
    .forEach(id=>{ const el=document.getElementById(id); if(el) el.value=''; });
  document.getElementById('add-date').value=today();
  document.getElementById('stock-search').value='';
  document.getElementById('stock-search').style.display='block';
  document.getElementById('selected-badge').style.display='none';
  document.getElementById('search-dropdown').style.display='none';
  document.getElementById('atr-section').style.display='none';
  document.getElementById('suggestions').innerHTML='';
  document.getElementById('atr-days').value=14;
  document.getElementById('atr-sell-mult').value=3;
  document.getElementById('atr-buy-mult').value=5;
  document.getElementById('atr-take-mult').value=2;
  atrRawData=[];
  openModal('modal-add');
  setTimeout(()=>document.getElementById('stock-search').focus(),200);
}
function submitAddStock(){
  const code=document.getElementById('add-code').value.trim();
  const name=document.getElementById('add-name').value.trim();
  const price=parseFloat(document.getElementById('add-price').value);
  const shares=parseInt(document.getElementById('add-shares').value);
  if(!code||isNaN(price)||isNaN(shares)||shares<=0){ alert('請先搜尋選擇股票，並填入買入價格和股數'); return; }

  const triggers={
    sell1:parseFloat(document.getElementById('add-sell1').value)||null,
    buy2:parseFloat(document.getElementById('add-buy2').value)||null,
    take:parseFloat(document.getElementById('add-take').value)||null,
  };
  const note=document.getElementById('add-note').value.trim();
  const initDate=document.getElementById('add-date').value||today();

  if(editStockId){
    // 編輯模式：更新現有股票
    const s=state.stocks.find(x=>x.id===editStockId);
    if(s){
      s.code=code; s.name=name;
      s.initPrice=price; s.initShares=shares;
      s.initDate=initDate; s.note=note;
      s.triggers=triggers;
    }
    editStockId=null;
    // 還原 modal 標題
    document.querySelector('#modal-add .modal-title').textContent='新增股票';
    document.querySelector('#modal-add .modal-footer .btn-primary').textContent='建立股票';
    saveState(); closeModal('modal-add'); selectStock(s.id);
  } else {
    // 新增模式
    const stock={
      id:uid(),code,name:name||code,
      initPrice:price,initShares:shares,
      initDate,currentPrice:price,
      triggers,transactions:[],notes:[],note
    };
    state.stocks.push(stock); saveState(); closeModal('modal-add');
    activeId=stock.id; render();
  }
}

