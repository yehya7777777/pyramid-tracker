function updateTxHint(){
  const hints={
    dca:'定期定額：與初始建倉合併計算均攤成本，不佔用補倉次數統計',
    buy:'補倉：金字塔加碼，計入均攤成本並更新持股數',
    sell:'減倉 / 高拋：按比例降低持股，不影響剩餘成本'
