<script>
// ══ CONFIG ══
const FM_TOKEN='eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJ1c2VyX2lkIjoiYjIyNTU0MDQ3IiwiZW1haWwiOiJiMjI1NTQwNDdAZ21haWwuY29tIiwidG9rZW5fdmVyc2lvbiI6MH0.TcnPVxtRZVOXcmSl8IG93BH6sdaqyZRhF71r-XsOcNQ';
const FM_URL='https://api.finmindtrade.com/api/v4/data';
const STORE_KEY='pyramid_v3';

// ══ STATE ══
function loadState(){
  try{ const r=localStorage.getItem(STORE_KEY); return r?JSON.parse(r):{stocks:[]}; }
  catch(e){ return {stocks:[]}; }
}
let state=loadState();
window._localState=state;
let activeId=null;
let atrRawData=[];
let isSyncing=false;

function saveState(){
  try{ localStorage.setItem(STORE_KEY,JSON.stringify(state)); }catch(e){}
  // 同步到 Firestore（若已登入）
  if(window._fbSave){
    isSyncing=true; setSyncDot('syncing');
    window._fbSave(state).then(()=>{ isSyncing=false; setSyncDot('ok'); })
      .catch(()=>{ isSyncing=false; setSyncDot('error'); });
  }
}

function setSyncDot(status){
  const dot=document.getElementById('sync-dot');
  if(!dot) return;
  const colors={ok:'var(--green)',syncing:'var(--yellow)',error:'var(--red)'};
  const titles={ok:'已同步',syncing:'同步中…',error:'同步失敗'};
  dot.style.background=colors[status]||'var(--text3)';
  dot.title=titles[status]||'';
}

// ══ FIREBASE CALLBACKS ══
window._onAuthChange = (user) => {
  const btnSignin=document.getElementById('btn-signin');
  const userInfo=document.getElementById('user-info');
  const avatar=document.getElementById('user-avatar');
  const userName=document.getElementById('user-name');
  if(user){
    btnSignin.style.display='none';
    userInfo.style.display='flex';
    avatar.src=user.photoURL||'';
    userName.textContent=user.displayName||user.email||'';
    setSyncDot('ok');
  } else {
    btnSignin.style.display='flex';
    userInfo.style.display='none';
  }
};

window._onRemoteData = (data) => {
  if(!data?.payload) return;
  try{
    const remote=JSON.parse(data.payload);
    if(!remote?.stocks) return;
    // 合併：Firestore 為主，保留本地有但 remote 沒有的股票
    const remoteIds=new Set(remote.stocks.map(s=>s.id));
    const localOnly=(state.stocks||[]).filter(s=>!remoteIds.has(s.id));
    state.stocks=[...remote.stocks,...localOnly];
    window._localState=state;
    try{ localStorage.setItem(STORE_KEY,JSON.stringify(state)); }catch(e){}
    render();
    setSyncDot('ok');
  }catch(e){}
};

// ══ UTILS ══
function uid(){ return Date.now().toString(36)+Math.random().toString(36).slice(2,6); }
function fmt(n,d=2){ return isNaN(n)||n===null?'—':Number(n).toLocaleString('zh-TW',{minimumFractionDigits:d,maximumFractionDigits:d}); }
function today(){ return new Date().toISOString().slice(0,10); }
function daysSince(d){ return Math.max(0,Math.floor((Date.now()-new Date(d))/86400000)); }

// ══ STOCK CALC ══
// dca & buy → add to cost basis; sell → reduce proportionally
function calcStock(s){
  let shares=s.initShares, costTotal=s.initPrice*s.initShares;
  for(const tx of (s.transactions||[])){
    if(tx.type==='buy'||tx.type==='dca'){
      costTotal+=tx.price*tx.shares; shares+=tx.shares;
    } else {
      const cpp=shares>0?costTotal/shares:0;
      costTotal-=cpp*tx.shares; shares-=tx.shares;
    }
  }
  return { shares, avgCost:shares>0?costTotal/shares:0, costTotal };
}

// ══ RENDER ══
function render(){ renderSidebar(); activeId?selectStock(activeId,false):showEmpty(); }
function showEmpty(){
  document.getElementById('empty-state').style.display='flex';
  document.getElementById('stock-detail').style.display='none';
}
function renderSidebar(){
  document.getElementById('stock-count').textContent=state.stocks.length+' 檔';
  const list=document.getElementById('stock-list');
  const q=(document.getElementById('sidebar-search')?.value||'').toLowerCase().trim();
  const stocks=q
    ? state.stocks.filter(s=>s.code.toLowerCase().includes(q)||s.name.toLowerCase().includes(q))
    : state.stocks;
  if(!stocks.length){
    list.innerHTML=`<div style="padding:18px;text-align:center;color:var(--text3);font-size:13px">${q?'找不到符合的股票':'尚無持倉'}</div>`;
    return;
  }
  list.innerHTML=stocks.map(s=>{
    const c=calcStock(s);
    const price=s.currentPrice??c.avgCost;
    const pct=c.avgCost>0?(price-c.avgCost)/c.avgCost*100:0;
    const alert=nearTrigger(s,price);
    return `<div class="stock-item ${s.id===activeId?'active':''}" onclick="selectStock('${s.id}')">
      <div class="stock-item-header">
        <span class="stock-code">${s.code}</span>
        <div style="display:flex;align-items:center;gap:5px">
          ${alert?'<div class="alert-dot"></div>':''}
          <span class="stock-pnl ${pct>=0?'pos':'neg'}">${pct>=0?'+':''}${fmt(pct,1)}%</span>
        </div>
      </div>
      <div class="stock-name">${s.name}</div>
      <div class="stock-mini">
        <span class="mini-chip">${fmt(c.shares,0)} 股</span>
        <span class="mini-chip">均 $${fmt(c.avgCost)}</span>
      </div>
    </div>`;
  }).join('');
}

function nearTrigger(s,price){
  if(!price) return false;
  return [s.triggers?.sell1,s.triggers?.buy2,s.triggers?.take].some(t=>t&&Math.abs(price-t)/t<0.03);
}

function selectStock(id, updateSidebar=true){
  activeId=id;
  const s=state.stocks.find(x=>x.id===id);
  if(!s){ showEmpty(); return; }
  document.getElementById('empty-state').style.display='none';
  document.getElementById('stock-detail').style.display='block';
  renderDetail(s);
  if(updateSidebar) renderSidebar();
  document.getElementById('sidebar').classList.remove('mobile-open');
}

function renderDetail(s){
  const c=calcStock(s);
  const price=s.currentPrice??c.avgCost;
  const pnlPct=c.avgCost>0?(price-c.avgCost)/c.avgCost*100:0;
  const pnlAmt=(price-c.avgCost)*c.shares;
  const t=s.triggers||{};
  const totalVal=price*c.shares;

  function dist(trigger){
    if(!trigger||!price) return '未設定';
    const d=trigger-price, p=d/price*100;
    return `${d>=0?'+':''}${fmt(d)} (${p>=0?'+':''}${fmt(p,1)}%)`;
  }
  function distColor(trigger){
    if(!trigger||!price) return 'var(--text3)';
    const pct=Math.abs((trigger-price)/price*100);
    return pct<3?'var(--yellow)':'var(--text2)';
  }

  // ── 手續費累計計算 ──
  const isETF = /^00\d/.test(s.code); // ETF 判斷
  const discount = s.feeDiscount ?? 28; // 預設28折
  function calcTxFee(txPrice, txShares, txType){
    const amt = txPrice * txShares;
    const fee = Math.max(Math.floor(amt * 0.001425 * discount/100), 20);
    const tax = txType==='sell' ? Math.floor(amt * (isETF?0.001:0.003)) : 0;
    return { fee, tax, total: fee+tax };
  }
  // 初始建倉手續費
  const initFee = Math.max(Math.floor(s.initPrice*s.initShares*0.001425*discount/100), 20);
  let totalFee = initFee;
  let totalTax = 0;
  (s.transactions||[]).forEach(tx=>{
    const r = calcTxFee(tx.price, tx.shares, tx.type);
    totalFee += r.fee;
    totalTax += r.tax;
  });
  // 未實現稅（若現在賣出所有持股會課多少稅）
  const unrealizedTax = Math.floor(totalVal * (isETF?0.001:0.003));

  const typeLabel={buy:'補倉',sell:'減倉',dca:'定期定額'};
  const typeClass={buy:'buy',sell:'sell',dca:'dca'};

  const txRows=(s.transactions||[]).slice().reverse().map(tx=>{
    const r = calcTxFee(tx.price, tx.shares, tx.type);
    return `<tr>
      <td><span class="tx-type ${typeClass[tx.type]||'buy'}">${typeLabel[tx.type]||tx.type}</span></td>
      <td class="tx-mono">$${fmt(tx.price)}</td>
      <td class="tx-mono">${fmt(tx.shares,0)}</td>
      <td class="tx-mono">$${fmt(tx.price*tx.shares,0)}</td>
      <td class="tx-mono" style="color:var(--yellow);font-size:13px">$${fmt(r.fee,0)}${tx.type==='sell'?`<br><span style="color:var(--red);font-size:12px">稅$${fmt(r.tax,0)}</span>`:''}</td>
      <td><span class="tx-note">${tx.flag?'⚠ ':''}${tx.note||'—'}</span></td>
      <td class="tx-mono" style="color:var(--text3);font-size:13px">${tx.date}</td>
      <td style="display:flex;gap:4px">
        <button class="btn btn-ghost btn-sm btn-icon delete-btn" onclick="openEditTx('${s.id}','${tx.id}')" title="編輯">✎</button>
        <button class="btn btn-danger btn-sm btn-icon delete-btn" onclick="deleteTx('${s.id}','${tx.id}')">×</button>
      </td>
    </tr>`;
  }).join('');

  const notes=(s.notes||[]).slice().reverse().map(n=>`
    <div class="note-item ${n.type}">
      <div style="font-size:16px">${n.type==='warn'?'⚠️':'ℹ️'}</div>
      <div style="flex:1"><div class="note-text">${n.text}</div><div class="note-date">${n.date}</div></div>
      <button class="btn btn-ghost btn-sm btn-icon" onclick="deleteNote('${s.id}','${n.id}')">×</button>
    </div>`).join('');

  document.getElementById('stock-detail').innerHTML=`
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;flex-wrap:wrap;gap:10px">
      <div>
        <div style="display:flex;align-items:baseline;gap:10px;flex-wrap:wrap">
          <h1 style="font-size:26px;font-weight:700;font-family:var(--mono)">${s.code}</h1>
          <span style="font-size:17px;color:var(--text2)">${s.name}</span>
        </div>
        <p style="font-size:13px;color:var(--text3);margin-top:4px">
          建倉 ${s.initDate} &nbsp;·&nbsp; 初始 $${fmt(s.initPrice)} × ${fmt(s.initShares,0)} 股
          ${s.note?`&nbsp;·&nbsp; ${s.note}`:''}
        </p>
